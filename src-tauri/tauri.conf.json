{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "AI Novel Writer",
  "version": "0.1.0",
  "identifier": "com.ai-novel.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "AI Novel Writer",
        "width": 1400,
        "height": 900
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "publisher": "yg1987",
    "copyright": "Copyright (c) 2026 yg1987",
    "homepage": "https://github.com/yg1987/ai-novel",
    "license": "MIT",
    "licenseFile": "../LICENSE",
    "shortDescription": "AI-powered desktop writing tool for web novels.",
    "longDescription": "AI Novel Writer is a local-first desktop writing tool for web novel authors, with project management, AI-assisted writing, story settings, outlines, reviews, and more.",
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": "^https://github\\.com/yg1987/ai-novel(?:/.*)?$"
    }
  }
}
